{
  "name": "@tutti-os/workspace-terminal",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./contracts": "./src/contracts/index.ts",
    "./i18n": "./src/i18n/index.ts",
    "./react": "./src/react/index.ts",
    "./styles.css": "./src/styles/terminal.css",
    "./workbench": "./src/workbench/index.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tutti-os/tutti.git",
    "directory": "packages/workspace/terminal"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && node ../../../tools/scripts/copy-package-assets.mjs src/styles dist/styles",
    "test": "node --test --experimental-strip-types ./src/**/*.test.ts",
    "typecheck": "node ../../../tools/scripts/run-tsgo-typecheck.mjs"
  },
  "dependencies": {
    "@tutti-os/ui-i18n-runtime": "workspace:*",
    "@tutti-os/ui-react-hooks": "workspace:*",
    "@tutti-os/ui-system": "workspace:*",
    "@tutti-os/workbench-surface": "workspace:*",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0"
  },
  "devDependencies": {
    "@tutti-os/config-tsconfig": "workspace:*",
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "tutti": {
    "tailwindSourceRoot": "src"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./contracts": {
        "types": "./dist/contracts/index.d.ts",
        "import": "./dist/contracts/index.js"
      },
      "./i18n": {
        "types": "./dist/i18n/index.d.ts",
        "import": "./dist/i18n/index.js"
      },
      "./react": {
        "types": "./dist/react/index.d.ts",
        "import": "./dist/react/index.js"
      },
      "./styles.css": "./dist/styles/terminal.css",
      "./workbench": {
        "types": "./dist/workbench/index.d.ts",
        "import": "./dist/workbench/index.js"
      }
    },
    "types": "./dist/index.d.ts"
  }
}
