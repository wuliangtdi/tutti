{
  "name": "@tutti-os/workspace-issue-manager",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./assets/workspace-dock-task.png": {
      "types": "./src/assets/workspace-dock-task.d.ts",
      "default": "./src/assets/workspace-dock-task.png"
    },
    "./contracts": "./src/contracts/index.ts",
    "./core": "./src/core/index.ts",
    "./i18n": "./src/i18n/index.ts",
    "./openapi/issue-manager.v1.yaml": "./openapi/issue-manager.v1.yaml",
    "./services": "./src/services/index.ts",
    "./ui": "./src/ui/index.ts",
    "./workbench/constants": "./src/workbench/constants.ts",
    "./workbench": "./src/workbench/index.ts"
  },
  "files": [
    "dist",
    "openapi",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tutti-os/tutti.git",
    "directory": "packages/workspace/issue-manager"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && node ../../../tools/scripts/copy-package-assets.mjs src/assets dist/assets",
    "test": "tsx --test \"./src/**/*.test.ts\"",
    "typecheck": "node ../../../tools/scripts/run-tsgo-typecheck.mjs"
  },
  "dependencies": {
    "@tutti-os/ui-i18n-runtime": "workspace:*",
    "@tutti-os/ui-react-hooks": "workspace:*",
    "@tutti-os/ui-rich-text": "workspace:*",
    "@tutti-os/ui-system": "workspace:*",
    "@tutti-os/workbench-surface": "workspace:*",
    "@tutti-os/workspace-file-reference": "workspace:*",
    "@tutti-os/workspace-file-preview": "workspace:*",
    "@tutti-os/workspace-user-project": "workspace:*",
    "valtio": "^2.3.2"
  },
  "devDependencies": {
    "@tutti-os/config-tsconfig": "workspace:*",
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.22.3",
    "typescript": "^5.8.3",
    "valtio": "^2.3.2"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "valtio": "^2.3.2"
  },
  "tutti": {
    "tailwindSourceRoot": "src"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./assets/workspace-dock-task.png": {
        "types": "./dist/assets/workspace-dock-task.d.ts",
        "default": "./dist/assets/workspace-dock-task.png"
      },
      "./contracts": {
        "types": "./dist/contracts/index.d.ts",
        "import": "./dist/contracts/index.js"
      },
      "./core": {
        "types": "./dist/core/index.d.ts",
        "import": "./dist/core/index.js"
      },
      "./i18n": {
        "types": "./dist/i18n/index.d.ts",
        "import": "./dist/i18n/index.js"
      },
      "./openapi/issue-manager.v1.yaml": "./openapi/issue-manager.v1.yaml",
      "./services": {
        "types": "./dist/services/index.d.ts",
        "import": "./dist/services/index.js"
      },
      "./ui": {
        "types": "./dist/ui/index.d.ts",
        "import": "./dist/ui/index.js"
      },
      "./workbench/constants": {
        "types": "./dist/workbench/constants.d.ts",
        "import": "./dist/workbench/constants.js"
      },
      "./workbench": {
        "types": "./dist/workbench/index.d.ts",
        "import": "./dist/workbench/index.js"
      }
    },
    "types": "./dist/index.d.ts"
  }
}
