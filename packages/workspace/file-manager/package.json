{
  "name": "@tutti-os/workspace-file-manager",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./i18n": "./src/i18n/index.ts",
    "./services": "./src/services/index.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tutti-os/tutti.git",
    "directory": "packages/workspace/file-manager"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && node ../../../tools/scripts/copy-package-assets.mjs src/assets dist/assets",
    "test": "node --test --experimental-strip-types \"./src/**/*.test.ts\"",
    "typecheck": "node ../../../tools/scripts/run-tsgo-typecheck.mjs"
  },
  "dependencies": {
    "@tutti-os/ui-i18n-runtime": "workspace:*",
    "@tutti-os/ui-system": "workspace:*",
    "@tutti-os/workspace-file-preview": "workspace:*"
  },
  "devDependencies": {
    "@tutti-os/config-tsconfig": "workspace:*",
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "valtio": "^2.3.2"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "valtio": "^2.3.2"
  },
  "tutti": {
    "tailwindSourceRoot": "src"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./i18n": {
        "types": "./dist/i18n/index.d.ts",
        "import": "./dist/i18n/index.js"
      },
      "./services": {
        "types": "./dist/services/index.d.ts",
        "import": "./dist/services/index.js"
      }
    },
    "types": "./dist/index.d.ts",
    "typesVersions": {
      "*": {
        "i18n": [
          "./dist/i18n/index.d.ts"
        ],
        "services": [
          "./dist/services/index.d.ts"
        ]
      }
    }
  }
}
