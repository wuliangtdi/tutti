{
  "name": "@tutti-os/ui-rich-text",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./at-panel": "./src/at-panel/index.ts",
    "./at-panel/index.css": "./src/at-panel/mentionPalette.css",
    "./at-panel/model": "./src/at-panel/model.ts",
    "./core": "./src/core/index.ts",
    "./editor": "./src/editor/index.ts",
    "./plugins": "./src/plugins/index.ts",
    "./types": "./src/types/index.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tutti-os/tutti.git",
    "directory": "packages/ui/rich-text"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "node --test --experimental-strip-types \"./src/**/*.test.ts\"",
    "typecheck": "node ../../../tools/scripts/run-tsgo-typecheck.mjs"
  },
  "dependencies": {
    "@tutti-os/ui-i18n-runtime": "workspace:*",
    "@tutti-os/ui-system": "workspace:*",
    "@tiptap/core": "^3.23.6",
    "@tiptap/extension-document": "^3.23.6",
    "@tiptap/extension-hard-break": "^3.23.6",
    "@tiptap/extension-paragraph": "^3.23.6",
    "@tiptap/extension-text": "^3.23.6",
    "@tiptap/react": "^3.23.6"
  },
  "devDependencies": {
    "@tutti-os/config-tsconfig": "workspace:*",
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "tutti": {
    "tailwindSourceRoot": "src"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./at-panel": {
        "types": "./dist/at-panel/index.d.ts",
        "import": "./dist/at-panel/index.js",
        "default": "./dist/at-panel/index.js"
      },
      "./at-panel/index.css": "./dist/at-panel/index.css",
      "./at-panel/model": {
        "types": "./dist/at-panel/model.d.ts",
        "import": "./dist/at-panel/model.js",
        "default": "./dist/at-panel/model.js"
      },
      "./core": {
        "types": "./dist/core/index.d.ts",
        "import": "./dist/core/index.js",
        "default": "./dist/core/index.js"
      },
      "./editor": {
        "types": "./dist/editor/index.d.ts",
        "import": "./dist/editor/index.js",
        "default": "./dist/editor/index.js"
      },
      "./plugins": {
        "types": "./dist/plugins/index.d.ts",
        "import": "./dist/plugins/index.js",
        "default": "./dist/plugins/index.js"
      },
      "./types": {
        "types": "./dist/types/index.d.ts",
        "import": "./dist/types/index.js",
        "default": "./dist/types/index.js"
      }
    },
    "types": "./dist/index.d.ts",
    "typesVersions": {
      "*": {
        "at-panel": [
          "./dist/at-panel/index.d.ts"
        ],
        "at-panel/model": [
          "./dist/at-panel/model.d.ts"
        ],
        "core": [
          "./dist/core/index.d.ts"
        ],
        "editor": [
          "./dist/editor/index.d.ts"
        ],
        "plugins": [
          "./dist/plugins/index.d.ts"
        ],
        "types": [
          "./dist/types/index.d.ts"
        ]
      }
    }
  }
}
