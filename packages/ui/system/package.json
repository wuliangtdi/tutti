{
  "name": "@tutti-os/ui-system",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "types": "./src/index.ts",
  "sideEffects": [
    "./src/styles/*.css",
    "./dist/styles/*.css",
    "./dist/styles.css"
  ],
  "bin": {
    "tutti-ui-system-install-skill": "./agent/install-skill.mjs"
  },
  "imports": {
    "#components/*": "./src/components/*/index.tsx",
    "#icons/*": "./src/icons/*.tsx",
    "#lib/*": "./src/lib/*.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./components": "./src/components/index.ts",
    "./date-format": "./src/lib/date-format.ts",
    "./dev-vite": "./src/dev-vite.ts",
    "./icons": "./src/icons/index.ts",
    "./metadata": "./src/metadata/index.ts",
    "./styles.css": "./src/styles/index.css",
    "./utils": "./src/lib/utils.ts"
  },
  "files": [
    "dist",
    "agent",
    "AGENTS.md",
    "ui-system.md",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tutti-os/tutti.git",
    "directory": "packages/ui/system"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && node ../../../tools/scripts/copy-package-assets.mjs src/styles dist/styles src/metadata/components.json dist/metadata/components.json src/metadata/components.schema.json dist/metadata/components.schema.json",
    "dev:server": "tsx src/dev-server/server.ts",
    "typecheck": "node ../../../tools/scripts/run-tsgo-typecheck.mjs"
  },
  "dependencies": {
    "@fontsource-variable/lexend": "^5.2.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.4.2",
    "react-resizable-panels": "^4.11.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "tw-animate-css": "^1.3.1",
    "vaul": "^1.1.2",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@tutti-os/config-tsconfig": "workspace:*",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.3",
    "typescript": "^5.8.3",
    "vite": "^6.4.2"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "tutti": {
    "tailwindSourceRoot": "src"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./components": {
        "types": "./dist/components/index.d.ts",
        "import": "./dist/components/index.js"
      },
      "./date-format": {
        "types": "./dist/date-format.d.ts",
        "import": "./dist/date-format.js"
      },
      "./dev-vite": {
        "types": "./dist/dev-vite.d.ts",
        "import": "./dist/dev-vite.js"
      },
      "./icons": {
        "types": "./dist/icons/index.d.ts",
        "import": "./dist/icons/index.js"
      },
      "./metadata": {
        "types": "./dist/metadata/index.d.ts",
        "import": "./dist/metadata/index.js"
      },
      "./styles.css": "./dist/styles/index.css",
      "./utils": {
        "types": "./dist/utils.d.ts",
        "import": "./dist/utils.js"
      }
    },
    "types": "./dist/index.d.ts",
    "typesVersions": {
      "*": {
        "components": [
          "./dist/components/index.d.ts"
        ],
        "date-format": [
          "./dist/date-format.d.ts"
        ],
        "icons": [
          "./dist/icons/index.d.ts"
        ],
        "metadata": [
          "./dist/metadata/index.d.ts"
        ],
        "utils": [
          "./dist/utils.d.ts"
        ]
      }
    }
  }
}
