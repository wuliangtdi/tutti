{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tutti.dev/schemas/events/workspace/workspace-app.schema.json",
  "title": "WorkspaceApp",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "appId",
    "displayName",
    "version",
    "description",
    "authors",
    "repository",
    "iconUrl",
    "installed",
    "enabled",
    "status",
    "stateRevision",
    "launchUrl",
    "port",
    "failureReason",
    "lastError",
    "startedAtUnixMs",
    "updatedAtUnixMs",
    "source",
    "exportable",
    "tags",
    "localizations",
    "minimizeBehavior",
    "windowMinWidth",
    "windowMinHeight",
    "references"
  ],
  "properties": {
    "appId": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": ["string", "null"]
          },
          "avatarUrl": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "repository": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["type", "url"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["github"]
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "iconUrl": {
      "type": ["string", "null"]
    },
    "installed": {
      "type": "boolean"
    },
    "enabled": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": [
        "idle",
        "preparing",
        "starting",
        "running",
        "installed_pending_restart",
        "failed",
        "stopping"
      ]
    },
    "stateRevision": {
      "type": "integer",
      "format": "int64",
      "minimum": 0
    },
    "launchUrl": {
      "type": ["string", "null"]
    },
    "port": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 65535
    },
    "failureReason": {
      "type": ["string", "null"]
    },
    "lastError": {
      "type": ["string", "null"]
    },
    "startedAtUnixMs": {
      "type": ["integer", "null"],
      "format": "int64"
    },
    "updatedAtUnixMs": {
      "type": ["integer", "null"],
      "format": "int64"
    },
    "source": {
      "type": "string",
      "enum": ["builtin", "generated", "imported"]
    },
    "exportable": {
      "type": "boolean"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "localizations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["locale", "displayName", "description", "tags"],
        "properties": {
          "locale": {
            "type": "string",
            "minLength": 1
          },
          "displayName": {
            "type": ["string", "null"]
          },
          "description": {
            "type": ["string", "null"]
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "minimizeBehavior": {
      "type": "string",
      "enum": ["hibernate", "keep-mounted"]
    },
    "windowMinWidth": {
      "type": ["integer", "null"],
      "minimum": 280,
      "maximum": 1600
    },
    "windowMinHeight": {
      "type": ["integer", "null"],
      "minimum": 160,
      "maximum": 1200
    },
    "references": {
      "type": "object",
      "additionalProperties": false,
      "required": ["listSupported", "searchSupported"],
      "properties": {
        "listSupported": {
          "type": "boolean"
        },
        "searchSupported": {
          "type": "boolean"
        }
      }
    },
    "installProgress": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "userPhase",
        "overallPercent",
        "downloadedBytes",
        "totalBytes",
        "indeterminate"
      ],
      "properties": {
        "userPhase": {
          "type": "string",
          "enum": ["downloading", "installing", "starting"]
        },
        "overallPercent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "downloadedBytes": {
          "type": ["integer", "null"],
          "format": "int64"
        },
        "totalBytes": {
          "type": ["integer", "null"],
          "format": "int64"
        },
        "indeterminate": {
          "type": "boolean"
        }
      }
    }
  }
}
