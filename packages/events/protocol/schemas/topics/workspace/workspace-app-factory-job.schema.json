{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tutti.dev/schemas/events/workspace/workspace-app-factory-job.schema.json",
  "title": "WorkspaceAppFactoryJob",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "jobId",
    "workspaceId",
    "status",
    "prompt",
    "appId",
    "displayName",
    "description",
    "agentTargetId",
    "provider",
    "model",
    "reasoningEffort",
    "agentSessionId",
    "validationResult",
    "failureReason",
    "publishedVersion",
    "createdAtUnixMs",
    "updatedAtUnixMs"
  ],
  "properties": {
    "jobId": { "type": "string", "minLength": 1 },
    "workspaceId": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "generating",
        "preparing",
        "validating",
        "ready",
        "published",
        "failed",
        "canceled"
      ]
    },
    "prompt": { "type": "string" },
    "appId": { "type": ["string", "null"] },
    "displayName": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "agentTargetId": { "type": ["string", "null"] },
    "provider": { "type": ["string", "null"] },
    "model": { "type": ["string", "null"] },
    "reasoningEffort": { "type": ["string", "null"] },
    "agentSessionId": { "type": ["string", "null"] },
    "validationResult": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "failureReason": { "type": ["string", "null"] },
    "publishedVersion": { "type": ["string", "null"] },
    "createdAtUnixMs": { "type": "integer", "format": "int64" },
    "updatedAtUnixMs": { "type": "integer", "format": "int64" }
  }
}
