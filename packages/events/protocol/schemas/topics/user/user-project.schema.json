{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tutti.dev/schemas/events/topics/user/user-project.schema.json",
  "title": "UserProject",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "path",
    "label",
    "sectionKey",
    "createdAtUnixMs",
    "updatedAtUnixMs",
    "lastUsedAtUnixMs"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "path": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "sectionKey": { "type": "string", "minLength": 1 },
    "createdAtUnixMs": { "type": "integer", "format": "int64", "minimum": 0 },
    "updatedAtUnixMs": { "type": "integer", "format": "int64", "minimum": 0 },
    "lastUsedAtUnixMs": {
      "type": "integer",
      "format": "int64",
      "minimum": 0
    }
  }
}
