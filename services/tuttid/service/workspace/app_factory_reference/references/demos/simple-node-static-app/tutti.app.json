{
  "schemaVersion": "tutti.app.manifest.v1",
  "appId": "app_demo-simple-node-static",
  "version": "0.1.0",
  "name": "Simple Node Static Demo",
  "description": "Demonstrates a minimal custom Tutti workspace app.",
  "icon": {
    "type": "asset",
    "src": "icon.svg"
  },
  "runtime": {
    "bootstrap": "bootstrap.sh",
    "healthcheckPath": "/healthz"
  },
  "cli": {
    "manifest": "tutti.cli.json"
  },
  "author": {
    "name": "Tutti"
  },
  "tags": ["demo"],
  "localizationInfo": {
    "defaultLocale": "en",
    "additionalLocales": [
      {
        "locale": "zh-CN",
        "file": "locales/zh-CN/manifest.json"
      }
    ]
  }
}
