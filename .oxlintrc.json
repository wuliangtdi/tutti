{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "typescript/no-floating-promises": "off",
    "typescript/require-array-sort-compare": "off",
    "unicorn/no-useless-fallback-in-spread": "off",
    "unicorn/no-useless-spread": "off"
  },
  "env": {
    "builtin": true
  },
  "overrides": [
    {
      "files": ["apps/desktop/src/main/**"],
      "rules": {
        "no-restricted-globals": [
          "error",
          {
            "name": "fetch",
            "message": "Outbound HTTP from desktop main must use net/outboundFetch (routes through Chromium's proxy stack); local daemon/loopback targets may disable this rule inline with a reason."
          }
        ]
      }
    }
  ],
  "ignorePatterns": [
    "**/.git/**",
    "**/.claude/**",
    "**/.codex/**",
    "**/.tutti-ui-system-dev/**",
    "**/.turbo/**",
    "**/dist/**",
    "**/generated/**",
    "**/node_modules/**",
    "**/out/**",
    "services/tuttid/builtin-apps/**",
    "**/src/internal/ported-source/**",
    "**/tsup.config.ts"
  ]
}
